# VoxScore — environment template.
# Copy to .env.local and fill in. NEVER commit .env.local. (.env* is gitignored.)
#
# ── Local development (no real secrets) ───────────────────────────────────────
# Run `pnpm db:start`, then `pnpm exec supabase status` and paste the printed
# local values below. The local anon/service keys are well-known DEV defaults,
# not real secrets — they only work against your local stack.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. NEVER expose to the client. Bypasses RLS.
SUPABASE_SERVICE_ROLE_KEY=

# AI Judge analyzer. Generate two independent 32+ byte secrets. The upload
# secret authorizes one short-lived recording session; the callback secret
# authenticates Analyzer results back to the web API.
ANALYZER_URL=http://127.0.0.1:8081
ANALYZER_UPLOAD_SECRET=
ANALYZER_CALLBACK_SECRET=

# ── Faz J (real keys — filled at the very end of the project) ─────────────────
# LLM scoring (swaps MockScoringProvider → a real provider). Set EITHER key;
# Anthropic (Claude) is PREFERRED, OpenAI is the fallback. Scores stay
# "Provisional AI Estimate" (metadata-only, never audio) on every provider.
ANTHROPIC_API_KEY=
# Optional: override the Claude scoring model (default: claude-haiku-4-5-20251001)
ANTHROPIC_SCORING_MODEL=
OPENAI_API_KEY=
# Optional: override the OpenAI scoring model (default: gpt-4o-mini)
OPENAI_SCORING_MODEL=
# Rate limiting (swaps InMemoryRateLimiter → UpstashRateLimiter)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Bot check (swaps NoopBotCheck → TurnstileBotCheck)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Optional: YouTube Data API v3 (catalog view counts + duration-matched badge;
# oEmbed needs no key)
YOUTUBE_API_KEY=
# Notifications send-side cron (vercel.json). Vercel automatically sends
# `Authorization: Bearer $CRON_SECRET` when invoking scheduled functions if
# this env var is set — /api/cron/send-notifications rejects everything else.
CRON_SECRET=
# Salt for the one-way network hash on verified listens (vote-burst
# detection). Server-only; rotating it orphans old hashes (harmless — the
# cron only compares hashes within a 24h window). Unset → no hash is stored.
ANTI_ABUSE_SALT=

# Native app integrity (sensitive mobile writes). Production web ALWAYS
# verifies native proof. Enable client generation in the EAS environment.
NATIVE_ATTESTATION_REQUIRED=false
EXPO_PUBLIC_NATIVE_ATTESTATION_ENABLED=false
# Android: numeric Cloud project number linked in Play Console.
EXPO_PUBLIC_PLAY_INTEGRITY_CLOUD_PROJECT_NUMBER=
# Base64 of the server-only Google service-account JSON, never NEXT_PUBLIC.
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON_B64=
# Must match apps/mobile/app.json and the Play Console listing.
GOOGLE_PLAY_PACKAGE_NAME=com.voxscore.app
# Comma-separated Play signing certificate SHA-256 digests returned by the API.
GOOGLE_PLAY_CERT_SHA256=
# iOS: 10-character Apple Developer Team ID. Use development only for dev builds.
APPLE_TEAM_ID=
APPLE_BUNDLE_ID=com.voxscore.app
APP_ATTEST_ENVIRONMENT=production
