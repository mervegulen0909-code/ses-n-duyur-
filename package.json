{
  "name": "voxscore",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "tsc --noEmit && pnpm -r typecheck",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:e2e": "pnpm --filter @voxscore/web test:e2e",
    "db:start": "supabase start",
    "db:stop": "supabase stop",
    "db:reset": "supabase db reset",
    "db:migrate": "supabase migration up",
    "db:types": "supabase gen types typescript --local > packages/db/src/types.ts",
    "seed:launch-catalog": "tsx scripts/seed-launch-catalog.ts",
    "curate:catalog": "tsx scripts/curate-catalog.ts"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.5",
    "@vitest/coverage-v8": "^2.1.8",
    "eslint": "^9.18.0",
    "expo-doctor": "1.20.0",
    "prettier": "^3.4.2",
    "supabase": "^2.105.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^2.1.8"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.2",
    "@voxscore/core": "workspace:*",
    "@voxscore/db": "workspace:*"
  },
  "pnpm": {
    "overrides": {
      "postcss@<8.5.12": "8.5.12",
      "uuid@<11.1.1": "11.1.1",
      "js-yaml@<4.3.0": "4.3.0",
      "shell-quote@<1.9.0": "1.9.0",
      "sharp@<0.35.0": "0.35.0"
    }
  }
}
